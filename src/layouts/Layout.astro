---
import Navbar from "../components/layout/Navbar.astro";
import "../styles/global.css";
// import "aos/dist/aos.css";

// Fonts
import '@fontsource/inter/400.css';  // Regular
import '@fontsource/inter/600.css';  // Semi-bold
import '@fontsource/fira-code/400.css';  // Regular
import '@fontsource/fira-code/600.css';  // Semi-bold

import Footer from "../components/layout/Footer.astro";
import { ClientRouter } from "astro:transitions";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="flex min-h-screen flex-col w-full">
    <Navbar />
    <main class="w-full flex-1 pt-20">
      <slot />
    </main>
    <Footer />
    </div>
  </body>
</html>


<script>
  import AOS from "aos";
  import "aos/dist/aos.css";

  // Función para inicializar/refrescar AOS
  const initAOS = () => {
    AOS.init({
      once: false,  
      mirror: true,     
      duration: 700,
      offset: 120,
      easing: 'ease-in-out',
      delay: 0,
      anchorPlacement: 'top-bottom',
    });
  };

  // Función para refrescar AOS
  const refreshAOS = () => {
    AOS.refresh();
  };

  // Inicializa al cargar la página
  document.addEventListener('DOMContentLoaded', initAOS);

  // Re-inicializa después de cada navegación (si usas View Transitions)
  document.addEventListener('astro:page-load', () => {
    initAOS();
    // Pequeño delay para asegurar que el DOM esté listo
    setTimeout(refreshAOS, 100);
  });

  // Refrescar cuando termine la transición
  document.addEventListener('astro:after-swap', refreshAOS);
</script>

<script is:inline src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>


