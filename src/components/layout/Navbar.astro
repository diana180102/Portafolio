---
import { Skull, FileCodeCorner } from '@lucide/astro';
import FlowbiteInit from './FlowbiteInit.astro';
---
  
<header class="w-full  bg-black flex justify-center items-center fixed top-0 left-0 z-50 p-8">
<nav class=" h-20 w-[80%] rounded-2xl p-1  border shadow-b border-secondary ">

    <div class="flex flex-wrap items-center justify-between max-w-7xl mx-auto p-4">
        <div class="flex items-center space-x-3 rtl:space-x-reverse">
            <FileCodeCorner color="#5DD62C" />
            <span class="self-center text-xl font-normal whitespace-nowrap text-white font-sans">Ing.Diana Mayorga</span>
        </div>
        <!-- Botón de menu -->
        <div class="flex items-center lg:order-2 space-x-1 lg:space-x-2 rtl:space-x-reverse">
            
            <button data-collapse-toggle="mega-menu" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-[#63F88B] rounded-lg lg:hidden  hover:text-[#BBFCCC] focus:outline-none focus:ring-1 focus:ring-default" aria-controls="mega-menu" aria-expanded="false">
                <span class="sr-only">Open main menu</span>
                <svg class="w-6 h-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M5 7h14M5 12h14M5 17h14"/></svg>
            </button>
        </div>


        <div id="mega-menu" class="items-center justify-between hidden w-full lg:flex lg:w-auto lg:order-1">
            <ul class="flex flex-col mt-8 rounded-xs bg-secondary lg:bg-transparent arounded-base font-700 font-sans font-medium lg:border-0 lg:flex-row lg:mt-0 lg:space-x-8 rtl:space-x-reverse">
                <li>
                    <a href="/" class="block py-2 px-3 text-black  lg:text-secondary border-light hover:bg-primary font-sans font-light lg:hover:bg-transparent lg:border-0 lg:hover:text-primary lg:p-0" aria-current="page" data-astro-prefetch>Inicio</a>
                </li>

                <li>
                    <a href="/#about" class="block py-2 px-3 text-white  border-light font-sans font-light hover:bg-[#10c03f] lg:hover:bg-transparent lg:border-0 lg:hover:text-secondary lg:p-0" data-astro-prefetch>About</a>
                </li>

                

                <li>
                    <a href="/#experience" class="block py-2 px-3 text-white  border-light font-sans font-light hover:bg-[#10c03f] lg:hover:bg-transparent lg:border-0 lg:hover:text-secondary lg:p-0" data-astro-prefetch>Experiencia</a>
                </li>
               
                <li>
                    <a href="/projects" class="block py-2 px-3 text-white  border-light font-sans font-light hover:bg-[#10c03f] lg:hover:bg-transparent lg:border-0 lg:hover:text-secondary lg:p-0" data-astro-prefetch>Proyectos</a>
                </li>
                <li>
                    <a href="/certificates" class="block py-2 px-3 text-white  border-light font-sans font-light hover:bg-[#10c03f] lg:hover:bg-transparent lg:border-0 lg:hover:text-secondary lg:p-0" data-astro-prefetch>Certificaciones</a>
                </li>
                <li>
                    <a href="#footer" class="block py-2 px-3 text-white  border-light font-sans font-light hover:bg-[#10c03f] lg:hover:bg-transparent lg:border-0 lg:hover:text-secondary lg:p-0" data-astro-prefetch>Contacto</a>
                </li>
            </ul>
        </div>
    </div>
</nav>
</header>

<FlowbiteInit />


