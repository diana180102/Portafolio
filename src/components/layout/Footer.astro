        <div class="md:flex md:justify-between">
            <!-- Logo -->
          <div class="mb-6 md:mb-0 md:w-1/2">
             <p class="text-4xl boujee-text">Ing. Diana Mayorga</p>
             <p class="text-gray-100 font-mono">Ingeniera de sistemas & desarrolladora de software, me especializo en la construcción y diseño de REST APIs que priorizan claridad y consistencia.</p>
          </div>

          <!-- Columnas del footer -->
          <div class="grid grid-cols-2 gap-8 sm:gap-6 sm:grid-cols-2">
              <div>
                  <h2 class="mb-6 text-sm font-semibold font-sans text-secondary uppercase">Contacto</h2>
                  <ul class="text-white font-normal font-mono">
                      <li class="mb-4">
                          <a href="mailto:dianacm1806gmail.com" class="hover:underline">dianacm1806@gmail.com</a>
                      </li>

                  </ul>
              </div>
              <div>
