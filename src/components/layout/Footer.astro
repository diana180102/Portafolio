      <div class="sm:flex sm:items-center sm:justify-between">
          <span class="text-sm text-secondary sm:text-center">© 2026 Diana Mayorga. All Rights Reserved.
          </span>
          <div class="flex mt-4 sm:justify-center sm:mt-0">
          
            <a href="#" class="text-secondary hover:text-heading ms-5">
               <Github color="#5dd62c" />
            </a>
            <a href="https://gitlab.com/diana180102" class="text-secondary hover:text-heading ms-5">  
